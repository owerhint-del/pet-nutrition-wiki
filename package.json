{
  "name": "pet-nutrition-wiki",
  "version": "1.0.0",
  "description": "Wiki about natural pet nutrition - powered by Payload CMS",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "next start -p 3001",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "payload": "payload",
    "import-content": "tsx scripts/import-content.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.78.0",
    "@payloadcms/next": "^3.78.0",
    "@payloadcms/richtext-lexical": "^3.78.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.10.0",
    "next": "15.4.11",
    "payload": "^3.78.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
